/* CURSOR */
.cursor { width:10px; height:10px; background:var(--neon); border-radius:50%; position:fixed; top:0; left:0; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); box-shadow:0 0 12px var(--neon), 0 0 24px var(--neon); transition:transform 0.05s; }

/* NAV */
