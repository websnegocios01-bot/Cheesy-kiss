.review-avatar { width:38px; height:38px; border-radius:50%; background:var(--neon); display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:18px; color:var(--black); box-shadow:0 0 12px rgba(255,14,138,0.4); flex-shrink:0; }
.review-name { font-size:13px; font-weight:500; color:var(--cream); }
.review-meta { font-size:11px; color:rgba(255,240,247,0.35); letter-spacing:1px; }

/* INFO */
.info-section { background:var(--black); }
.info-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:3px; max-width:1200px; margin:0 auto; }
.info-box { background:var(--gray); padding:40px 32px; border:1px solid rgba(255,14,138,0.08); }
.info-box-title { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:3px; color:var(--neon); margin-bottom:24px; text-shadow:0 0 12px rgba(255,14,138,0.3); }
.info-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid rgba(255,240,247,0.06); }
.info-row:last-child { border:none; }
.info-day { font-size:13px; color:rgba(255,240,247,0.5); letter-spacing:1px; }
.info-time { font-size:13px; color:var(--cream); font-weight:500; }
.info-time.closed { color:rgba(255,14,138,0.5); }
.info-contact-item { display:flex; align-items:center; gap:14px; margin-bottom:18px; }
.info-contact-icon { font-size:20px; }
.info-contact-text { font-size:14px; color:rgba(255,240,247,0.7); }
.info-contact-text a { color:var(--neon); text-decoration:none; }
.info-contact-text a:hover { text-shadow:0 0 8px var(--neon); }

/* MAP STRIP */
.map-strip { background:var(--gray); padding:24px 52px; display:flex; align-items:center; justify-content:center; gap:16px; border-top:1px solid rgba(255,14,138,0.15); border-bottom:1px solid rgba(255,14,138,0.15); }
.map-strip a { background:var(--neon); color:var(--black); padding:12px 28px; font-size:12px; letter-spacing:2px; text-transform:uppercase; text-decoration:none; font-weight:500; box-shadow:0 0 20px rgba(255,14,138,0.4); transition:box-shadow 0.2s, transform 0.2s; }
.map-strip a:hover { box-shadow:0 0 36px rgba(255,14,138,0.7); transform:translateY(-2px); }
.map-addr { font-size:13px; letter-spacing:1.5px; color:rgba(255,240,247,0.5); }

/* CTA */
.cta-band { background:var(--neon); padding:80px 52px; text-align:center; position:relative; overflow:hidden; }
.cta-band::before { content:'CHEESY KISS'; position:absolute; font-family:'Bebas Neue',sans-serif; font-size:240px; letter-spacing:-8px; color:rgba(0,0,0,0.08); top:50%; left:50%; transform:translate(-50%,-50%); white-space:nowrap; pointer-events:none; }
.cta-band h2 { font-family:'Bebas Neue',sans-serif; font-size:clamp(48px,7vw,90px); color:var(--black); letter-spacing:3px; position:relative; z-index:1; line-height:1; }
.cta-band p { font-size:18px; color:rgba(0,0,0,0.6); margin:16px 0 36px; position:relative; z-index:1; }
.btn-black { background:var(--black); color:var(--cream); padding:16px 44px; text-decoration:none; font-size:13px; letter-spacing:2.5px; text-transform:uppercase; font-weight:500; display:inline-block; position:relative; z-index:1; transition:box-shadow 0.2s, transform 0.2s; clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px)); }
.btn-black:hover { box-shadow:0 10px 40px rgba(0,0,0,0.4); transform:translateY(-3px); }

/* FOOTER */
footer { background:var(--black); padding:48px 52px 28px; border-top:1px solid rgba(255,14,138,0.12); }
.footer-inner { max-width:1200px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:24px; }
.footer-logo { font-family:'Bebas Neue',sans-serif; font-size:32px; letter-spacing:5px; color:var(--neon); text-shadow:0 0 20px rgba(255,14,138,0.4); }
.footer-sub { font-size:12px; color:rgba(255,240,247,0.35); letter-spacing:1.5px; margin-top:4px; }
.footer-ig a { color:var(--neon); text-decoration:none; font-size:13px; letter-spacing:2px; }
.footer-ig a:hover { text-shadow:0 0 16px var(--neon); }
.footer-copy { width:100%; text-align:center; font-size:11px; color:rgba(255,240,247,0.2); margin-top:32px; letter-spacing:1.5px; }

/* ANIMATIONS */
@keyframes fadeUp { from{opacity:0;transform:translateY(28px);} to{opacity:1;transform:translateY(0);} }
.reveal { opacity:0; transform:translateY(30px); transition:opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity:1; transform:translateY(0); }

/* RESPONSIVE */
@media(max-width:900px) {
  nav { padding:16px 24px; }
  .nav-links { display:none; }
  section { padding:72px 24px; }
  .hero { padding:100px 24px 60px; }
  .about-inner { grid-template-columns:1fr; gap:48px; }
  .specials-grid { grid-template-columns:1fr; }
  .info-grid { grid-template-columns:1fr; }
  .hero-stats { gap:28px; }
  .menu-intro { flex-direction:column; align-items:flex-start; }
  .footer-inner { flex-direction:column; align-items:flex-start; }
}
</style>
