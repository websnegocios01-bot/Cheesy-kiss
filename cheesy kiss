.nav-logo { font-family:'Bebas Neue',sans-serif; font-size:30px; letter-spacing:5px; color:var(--neon); text-shadow:0 0 20px var(--neon), 0 0 40px var(--neon); }
.nav-links { display:flex; gap:36px; list-style:none; }
.nav-links a { text-decoration:none; color:rgba(255,240,247,0.65); font-size:12px; letter-spacing:2.5px; text-transform:uppercase; transition:color 0.2s, text-shadow 0.2s; }
