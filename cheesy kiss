.hero-bg { position:absolute; inset:0; z-index:0; background:radial-gradient(ellipse 60% 60% at 70% 50%, rgba(255,14,138,0.12) 0%, transparent 70%), radial-gradient(ellipse 40% 40% at 20% 80%, rgba(255,14,138,0.07) 0%, transparent 60%); }
.hero-grid { position:absolute; inset:0; z-index:0; background-image:linear-gradient(rgba(255,14,138,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,14,138,0.04) 1px, transparent 1px); background-size:60px 60px; }
.hero-bg-word { position:absolute; z-index:0; font-family:'Bebas Neue',sans-serif; font-size:360px; line-height:1; color:rgba(255,14,138,0.04); letter-spacing:-15px; right:-40px; top:50%; transform:translateY(-50%); white-space:nowrap; pointer-events:none; user-select:none; }
.hero-content { position:relative; z-index:2; max-width:700px; }
.hero-tag { display:inline-flex; align-items:center; gap:8px; border:1px solid rgba(255,14,138,0.45); background:rgba(255,14,138,0.08); padding:7px 18px; border-radius:40px; font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--neon); margin-bottom:28px; animation:fadeUp 0.7s ease both; }
.hero-tag::before { content:''; width:6px; height:6px; background:var(--neon); border-radius:50%; box-shadow:0 0 8px var(--neon); animation:blink 1.5s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
.hero-h1 { font-family:'Bebas Neue',sans-serif; font-size:clamp(80px,10vw,140px); line-height:0.88; letter-spacing:2px; animation:fadeUp 0.7s 0.12s ease both; }
.hero-h1 .line-pink { color:var(--neon); text-shadow:0 0 30px rgba(255,14,138,0.6), 0 0 60px rgba(255,14,138,0.3); display:block; }
.hero-sub { font-family:'Playfair Display',serif; font-style:italic; font-size:20px; color:rgba(255,240,247,0.5); margin:22px 0 40px; line-height:1.6; max-width:480px; animation:fadeUp 0.7s 0.24s ease both; }
.hero-btns { display:flex; gap:16px; flex-wrap:wrap; animation:fadeUp 0.7s 0.36s ease both; }
.btn-neon { background:var(--neon); color:var(--black); padding:15px 38px; border:none; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; letter-spacing:2.5px; text-transform:uppercase; text-decoration:none; display:inline-block; clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px)); box-shadow:0 0 24px rgba(255,14,138,0.5), 0 0 60px rgba(255,14,138,0.2); transition:box-shadow 0.25s, transform 0.25s; }
.btn-neon:hover { box-shadow:0 0 40px rgba(255,14,138,0.8), 0 0 80px rgba(255,14,138,0.4); transform:translateY(-3px); }
.btn-outline { background:transparent; color:var(--cream); padding:15px 38px; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; letter-spacing:2.5px; text-transform:uppercase; text-decoration:none; display:inline-block; border:1px solid rgba(255,240,247,0.25); transition:border-color 0.2s, color 0.2s, box-shadow 0.2s; }
.btn-outline:hover { border-color:var(--neon); color:var(--neon); box-shadow:0 0 20px rgba(255,14,138,0.2); }
.hero-stats { display:flex; gap:48px; margin-top:60px; animation:fadeUp 0.7s 0.48s ease both; }
.stat-n { font-family:'Bebas Neue',sans-serif; font-size:48px; color:var(--neon); text-shadow:0 0 20px rgba(255,14,138,0.5); line-height:1; }
.stat-l { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,240,247,0.4); margin-top:4px; }

/* SECTIONS */
section { padding:100px 52px; }
.section-tag { font-size:11px; letter-spacing:4px; text-transform:uppercase; color:var(--neon); margin-bottom:14px; display:flex; align-items:center; gap:10px; }
.section-tag::before { content:''; display:block; width:30px; height:1px; background:var(--neon); box-shadow:0 0 8px var(--neon); }
.section-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(48px,5vw,72px); letter-spacing:2px; line-height:1; margin-bottom:16px; }
.neon-divider { width:100%; height:1px; background:linear-gradient(90deg, transparent, var(--neon), transparent); box-shadow:0 0 12px var(--neon); opacity:0.4; }

/* ABOUT */
.about { background:var(--gray); }
.about-inner { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; max-width:1200px; margin:0 auto; }
.about-text p { font-size:16px; line-height:1.8; color:rgba(255,240,247,0.65); margin-bottom:18px; }
.about-text p strong { color:var(--neon); font-weight:500; }
.about-features { display:flex; flex-direction:column; gap:20px; margin-top:32px; }
.feature-item { display:flex; align-items:flex-start; gap:16px; padding:18px 22px; background:var(--gray2); border-left:2px solid var(--neon); }
.feature-icon { font-size:24px; flex-shrink:0; }
.feature-text h4 { font-size:14px; letter-spacing:1.5px; text-transform:uppercase; color:var(--cream); margin-bottom:4px; }
.feature-text p { font-size:13px; color:rgba(255,240,247,0.5); line-height:1.5; }
.about-visual { position:relative; display:flex; align-items:center; justify-content:center; }
.about-logo-big { font-family:'Bebas Neue',sans-serif; font-size:120px; line-height:1; color:var(--neon); text-shadow:0 0 40px rgba(255,14,138,0.6), 0 0 80px rgba(255,14,138,0.3); text-align:center; letter-spacing:4px; animation:glowPulse 3s ease-in-out infinite; }
@keyframes glowPulse { 0%,100%{text-shadow:0 0 40px rgba(255,14,138,0.6), 0 0 80px rgba(255,14,138,0.3);} 50%{text-shadow:0 0 60px rgba(255,14,138,0.9), 0 0 120px rgba(255,14,138,0.5), 0 0 200px rgba(255,14,138,0.2);} }
.about-address { text-align:center; margin-top:20px; font-size:13px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,240,247,0.4); }

/* MENU */
.menu-section { background:var(--black); }
.menu-intro { max-width:1200px; margin:0 auto 56px; display:flex; align-items:flex-end; justify-content:space-between; gap:24px; flex-wrap:wrap; }
.menu-intro-sub { font-size:16px; color:rgba(255,240,247,0.5); max-width:400px; line-height:1.7; }
.menu-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:2px; max-width:1200px; margin:0 auto; }
.menu-card { background:var(--gray); padding:28px; position:relative; overflow:hidden; transition:transform 0.25s, box-shadow 0.25s; border:1px solid rgba(255,14,138,0.05); }
.menu-card:hover { transform:translateY(-4px); box-shadow:0 20px 60px rgba(255,14,138,0.15); border-color:rgba(255,14,138,0.3); }
.menu-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:var(--neon); box-shadow:0 0 10px var(--neon); transform:scaleX(0); transform-origin:left; transition:transform 0.3s; }
.menu-card:hover::before { transform:scaleX(1); }
.card-cat { font-size:10px; letter-spacing:3px; text-transform:uppercase; color:var(--neon); margin-bottom:10px; }
.card-name { font-family:'Bebas Neue',sans-serif; font-size:26px; letter-spacing:2px; color:var(--cream); line-height:1.1; margin-bottom:10px; }
.card-desc { font-size:13px; color:rgba(255,240,247,0.45); line-height:1.6; margin-bottom:18px; }
.card-price { font-family:'Bebas Neue',sans-serif; font-size:32px; color:var(--neon); text-shadow:0 0 12px rgba(255,14,138,0.4); letter-spacing:1px; }
.card-emoji { position:absolute; bottom:16px; right:20px; font-size:44px; opacity:0.12; }

/* TAPAS */
.specials { background:var(--gray); }
.specials-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; max-width:1200px; margin:0 auto; }
.special-card { background:var(--black); border:1px solid rgba(255,14,138,0.15); padding:36px 28px; text-align:center; transition:border-color 0.2s, box-shadow 0.2s, transform 0.2s; }
.special-card:hover { border-color:var(--neon); box-shadow:0 0 40px rgba(255,14,138,0.15); transform:translateY(-4px); }
.special-icon { font-size:52px; margin-bottom:18px; display:block; }
.special-name { font-family:'Bebas Neue',sans-serif; font-size:28px; letter-spacing:2px; color:var(--neon); text-shadow:0 0 16px rgba(255,14,138,0.4); margin-bottom:12px; }
.special-desc { font-size:13px; color:rgba(255,240,247,0.5); line-height:1.7; }
.special-price { margin-top:16px; font-family:'Bebas Neue',sans-serif; font-size:28px; color:var(--neon); }

/* GALLERY */
.gallery { background:var(--black); overflow:hidden; padding:100px 0; }
.gallery-header { padding:0 52px 48px; max-width:1200px; margin:0 auto; }
.gallery-strip { display:flex; gap:3px; overflow:hidden; animation:scrollStrip 25s linear infinite; width:max-content; }
.gallery-strip:hover { animation-play-state:paused; }
@keyframes scrollStrip { 0%{transform:translateX(0);} 100%{transform:translateX(-50%);} }
.gal-item { width:260px; height:200px; flex-shrink:0; background:var(--gray); display:flex; align-items:center; justify-content:center; font-size:64px; border:1px solid rgba(255,14,138,0.1); position:relative; overflow:hidden; transition:border-color 0.2s; }
.gal-item:hover { border-color:var(--neon); }
.gal-item::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg, transparent 60%, rgba(255,14,138,0.12)); }
.gal-label { position:absolute; bottom:10px; left:12px; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,240,247,0.45); z-index:1; }

/* REVIEWS */
.reviews { background:var(--gray); }
.reviews-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:20px; max-width:1200px; margin:0 auto; }
.review-card { background:var(--black); border:1px solid rgba(255,14,138,0.1); padding:28px; transition:border-color 0.2s, box-shadow 0.2s; }
.review-card:hover { border-color:rgba(255,14,138,0.35); box-shadow:0 8px 40px rgba(255,14,138,0.08); }
.review-stars { color:var(--neon); font-size:16px; letter-spacing:2px; margin-bottom:14px; text-shadow:0 0 8px rgba(255,14,138,0.4); }
.review-text { font-size:14px; line-height:1.7; color:rgba(255,240,247,0.65); margin-bottom:20px; font-style:italic; }
